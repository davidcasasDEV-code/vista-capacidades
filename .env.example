PORT=3000

# mock: usa archivos locales para desarrollo
# aws: lee/escribe DynamoDB e invoca Lambda
DATA_MODE=mock

APP_REGION=us-east-1
APP_ACCESS_KEY_ID=pon-aqui-tu-access-key
APP_SECRET_ACCESS_KEY=pon-aqui-tu-secret-key
APP_SESSION_TOKEN=

DYNAMODB_TABLE_NAME=Data_Vista_Demanda_Capacidad
DYNAMODB_PRIMARY_KEY=key_mvp

# Tabla donde se guardan las vistas del usuario.
VIEWS_DYNAMODB_TABLE_NAME=Vistas_Demanda_Capacidad
VIEWS_DYNAMODB_PRIMARY_KEY=id

REFRESH_LAMBDA_NAME=Reporte_Vista_Capacidad
BACKEND_LAMBDA_NAME=Backend_Vista_Capacidad
